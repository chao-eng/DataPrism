{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:default",
    "dialog:default",
    "fs:default",
    "shell:default",
    "fs:allow-read-recursive",
    "fs:allow-write-recursive",
    "fs:allow-exists",
    "dialog:allow-open",
    "dialog:allow-save"
  ]
}
