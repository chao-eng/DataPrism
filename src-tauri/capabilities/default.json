{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "dialog:default",
    "fs:default",
    "shell:default",
    "fs:allow-read",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-write",
    "fs:allow-write-file",
    "fs:allow-exists",
    "dialog:allow-open",
    "dialog:allow-save",
    {
      "identifier": "fs:scope",
      "allow": ["$HOME/**"]
    }
  ]
}
